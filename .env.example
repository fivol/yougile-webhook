# YouGile webhook receiver — runtime config.
# Copy to .env and edit. All settings read from environment.

# === YouGile API (used by register_webhook.py and for resolving ALLOWED_USER_EMAILS on startup) ===
YOUGILE_API_KEY=your_yougile_api_key
YOUGILE_API_BASE=https://yougile.com/api-v2
YOUGILE_WEBHOOK_URL=https://your.public.domain/yougile/webhook
# Event spec: <object>-<action>. Regexp supported.
# E.g. chat_message-created, task-*, .*
YOUGILE_WEBHOOK_EVENT=chat_message-created
# Server-side filter applied to chat_message text (regexp). Empty = no filter.
YOUGILE_WEBHOOK_CHAT_FILTER=

# === HTTP server ===
HOST=127.0.0.1
PORT=9100

# === Claude trigger ===
# Comma-separated event types that fire claude. Empty = any event from the subscription.
CLAUDE_TRIGGER_EVENTS=chat_message-created
# Regex matched against the full payload JSON. Empty = always fire.
CLAUDE_TRIGGER_PATTERN=@Agent
# Path to the claude CLI binary.
CLAUDE_BIN=/path/to/claude
# Working directory claude runs in.
CLAUDE_WORKDIR=/path/to/your/project
# Extra CLI args (shlex-split, passed verbatim).
CLAUDE_EXTRA_ARGS=--dangerously-skip-permissions
# Path to prompt template (relative to project dir). `{event_json}` placeholder is replaced.
CLAUDE_PROMPT_TEMPLATE_FILE=prompt_template.txt
# Hard cap on concurrent claude processes (extra events are dropped with a warning).
CLAUDE_MAX_CONCURRENT=2

# === Sender whitelist ===
# Comma-separated emails allowed to trigger claude. Resolved to UUIDs on startup
# via /api-v2/users (requires YOUGILE_API_KEY). Empty = no sender filter (NOT recommended).
ALLOWED_USER_EMAILS=
# Payload keys searched (in order, both at top level and inside data/payload/message/object)
# to extract the sender's user UUID.
SENDER_KEYS=fromUserId,createdBy,userId,authorId,senderId,from
