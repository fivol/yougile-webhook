# YouGile webhook receiver — global configuration.
# Per-rule settings live in rules.toml. Copy this to .env and edit.

# === YouGile API ===
YOUGILE_API_KEY=your_yougile_api_key
YOUGILE_API_BASE=https://yougile.com/api-v2
YOUGILE_WEBHOOK_URL=https://your.public.domain/yougile/webhook
# Event spec used by register_webhook.py. Regex supported. Make it broad so
# rules.toml can route different event types.
YOUGILE_WEBHOOK_EVENT=(chat_message|task)-.*
# Optional server-side chat-text filter (regex).
YOUGILE_WEBHOOK_CHAT_FILTER=

# === HTTP server ===
HOST=127.0.0.1
PORT=9100

# === Claude defaults — can be overridden per rule in rules.toml ===
CLAUDE_BIN=/path/to/claude
CLAUDE_WORKDIR=/path/to/your/project
CLAUDE_EXTRA_ARGS=--dangerously-skip-permissions
# Hard cap on simultaneously-running claude processes. Excess events drop with a warning.
CLAUDE_MAX_CONCURRENT=2

# === Rules ===
RULES_FILE=rules.toml

# === Payload key lookup (used to extract sender / column / chat-id from events) ===
SENDER_KEYS=fromUserId,createdBy,userId,authorId,senderId,from
COLUMN_KEYS=columnId,toColumnId,newColumnId,destinationColumnId
# Keys checked (in order) for the chat/task UUID used to key claude sessions.
# Values that aren't UUID-shaped are skipped (so numeric message ids don't confuse us).
CHAT_ID_KEYS=chatId,id

# === Chat history fetched into the prompt on each spawn ===
# How many recent messages to include the FIRST time a chat triggers claude.
CHAT_HISTORY_FIRST_TIME_LIMIT=20
# How many to include on subsequent triggers (only messages newer than last seen).
CHAT_HISTORY_DELTA_LIMIT=50

# === Attachments (images & files dropped into YouGile chat) ===
# Each `/root/#file:<url>` marker in a message is downloaded into
# state/attachments/<chatId>/ and surfaced to the agent in the rendered chat
# history as `[image: /abs/path]` / `[file: /abs/path]`. The agent reads them
# with its Read tool (images render visually).
ATTACHMENTS_ENABLED=true
# Per-file size cap. Anything larger is skipped (the marker stays unresolved).
ATTACHMENT_MAX_BYTES=26214400
# Per-file download timeout in seconds.
ATTACHMENT_TIMEOUT_SECONDS=30
